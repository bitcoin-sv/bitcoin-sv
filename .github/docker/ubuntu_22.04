FROM ubuntu:22.04

ENV TZ=Europe/London

RUN set -xeu \
    && apt-get update \
    && apt-get install -y \
    build-essential libtool autotools-dev automake \ 
    cmake ninja-build \
    python3 pkg-config \
    libssl-dev libevent-dev bsdmainutils \
    libdb-dev libdb++-dev \
    libminiupnpc-dev \
    libzmq3-dev \
    python3-ecdsa python3-zmq python3-bip32utils \
    git \
    gcc-10 g++-10 \
    gcc-11 g++-11 \
    gcc-12 g++-12 \
    pip \
    libgoogle-perftools-dev \
    wget

RUN set -xeu \
    && wget https://archives.boost.io/release/1.86.0/source/boost_1_86_0.tar.gz \
    && tar -xzf boost_1_86_0.tar.gz \
    && cd boost_1_86_0 \
    && ./bootstrap.sh \
    && ./b2 install

RUN set -xeu && pip install flake8

ARG clang_version=19

RUN set -xeu \
    && apt-get update \
    && apt-get install -y lsb-release software-properties-common gnupg \
    && wget https://apt.llvm.org/llvm.sh \
    && chmod +x llvm.sh \
    && ./llvm.sh $clang_version
    
RUN set -xeu \
    && apt-get update \
    && apt-get install -y \
    clang-tidy-$clang_version \
    libfuzzer-${clang_version}-dev

RUN set -xeu \
    && apt-get update \
    && apt-get install -y \
    sysbench \
    zstd

RUN update-alternatives \
    --install /usr/bin/clang-tidy clang-tidy \
    /usr/bin/clang-tidy-$clang_version $clang_version

RUN set -xeu \
    && git clone https://github.com/brendangregg/FlameGraph.git

RUN set -xeu \
    && (type -p wget >/dev/null || (apt-get update && apt-get install wget -y)) \
        && mkdir -p -m 755 /etc/apt/keyrings \
        && wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
               | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
        && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
        && echo "deb [arch=$(dpkg --print-architecture) \
                 signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] \
                 https://cli.github.com/packages stable main" \
               | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
        && apt-get update \
        && apt-get install gh -y

COPY cargo/bitcoin.conf /root/.bitcoin/
